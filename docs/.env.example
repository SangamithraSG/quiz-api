# ─────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to Git!
# ─────────────────────────────────────────────

# Django secret key — generate one at: https://djecrety.ir
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quiz_db

# Google Gemini API key — get a FREE key at: https://aistudio.google.com
# Click "Get API key" → "Create API key"
GEMINI_API_KEY=AIzaSyBxGkMJ5jFTsGArOJNNJMTeXSlDpRSbtuw

# Allowed frontend origins (for CORS) — only needed in production
# CORS_ALLOWED_ORIGINS=https://your-frontend.com
